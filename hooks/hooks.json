{
  "PreToolUse": [
    {
      "matcher": "tool == \"Task\"",
      "hooks": [
        {
          "type": "command",
          "command": "node scripts/agent-boundary-guard.js validate \"$tool_input.name\""
        }
      ]
    },
    {
      "matcher": "tool == \"Edit\" || tool == \"Write\"",
      "hooks": [
        {
          "type": "command",
          "command": "node scripts/scope-manager.js check \"$file_path\""
        }
      ]
    },
    {
      "matcher": "tool == \"Bash\" && $tool_input.command matches \"(rm|del|rmdir|mkdir|move|copy)\"",
      "hooks": [
        {
          "type": "command",
          "command": "node scripts/scope-manager.js check \"$tool_input.command\""
        }
      ]
    },
    {
      "matcher": "tool == \"Bash\" && $tool_input.command matches \"(git|mkdir|rm)\"",
      "hooks": [
        {
          "type": "command",
          "command": "node scripts/architecture-validator.js check \"$tool_input.command\""
        }
      ]
    }
  ],
  "PostToolUse": [
    {
      "matcher": "tool == \"Edit\" && tool_input.file_path matches \"\\\\.(ts|tsx|js|jsx)$\"",
      "hooks": [
        {
          "type": "command",
          "command": "node scripts/check-console-log.js \"$file_path\""
        },
        {
          "type": "command",
          "command": "node scripts/security-scanner.js keys \"$file_path\""
        }
      ]
    },
    {
      "matcher": "tool == \"Bash\"",
      "hooks": [
        {
          "type": "command",
          "command": "node scripts/cross-platform-logger.js --event=post-bash --command=\"$tool_input.command\""
        }
      ]
    },
    {
      "matcher": "tool == \"Write\"",
      "hooks": [
        {
          "type": "command",
          "command": "node scripts/code-entropy.js scan \"$file_path\""
        },
        {
          "type": "command",
          "command": "node scripts/security-scanner.js scan \"$file_path\""
        }
      ]
    }
  ],
  "Start": [
    {
      "matcher": "*",
      "hooks": [
        {
          "type": "command",
          "command": "node scripts/flow-recovery.js check"
        },
        {
          "type": "command",
          "command": "node scripts/session-logger.js --event=start"
        },
        {
          "type": "command",
          "command": "node scripts/phase-manager.js status"
        },
        {
          "type": "command",
          "command": "node scripts/scope-manager.js show"
        },
        {
          "type": "command",
          "command": "node scripts/mcp-router.js enable"
        }
      ]
    }
  ],
  "Stop": [
    {
      "matcher": "*",
      "hooks": [
        {
          "type": "command",
          "command": "node scripts/session-logger.js --event=stop"
        },
        {
          "type": "command",
          "command": "node scripts/memory-manager.js validate"
        },
        {
          "type": "command",
          "command": "node scripts/memory-manager.js check memory-bank/项目进展.md"
        },
        {
          "type": "command",
          "command": "node scripts/memory-manager.js check memory-bank/学习记录.md"
        },
        {
          "type": "command",
          "command": "node scripts/memory-manager.js check memory-bank/技术决策.md"
        },
        {
          "type": "command",
          "command": "node scripts/security-scanner.js scan src"
        },
        {
          "type": "command",
          "command": "node scripts/code-entropy.js cleanup"
        }
      ]
    }
  ],
  "PreCommandUse": [
    {
      "matcher": "*",
      "hooks": [
        {
          "type": "command",
          "command": "node scripts/phase-validator.js \"$command\""
        }
      ]
    }
  ],
  "PostCommandUse": [
    {
      "matcher": "*",
      "hooks": [
        {
          "type": "command",
          "command": "node scripts/phase-manager.js next"
        }
      ]
    }
  ]
}
