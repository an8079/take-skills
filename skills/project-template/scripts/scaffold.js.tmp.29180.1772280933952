#!/usr/bin/env node

/**
 * Project Scaffolding Script
 *
 * Generates a complete project structure from templates.
 * Usage: node scaffold.js --template="<name>" --project="<name>"
 */

const fs = require('fs');
const path = require('path');

const args = process.argv.slice(2);
const params = {};

args.forEach(arg => {
  if (arg.startsWith('--')) {
    const parts = arg.substring(2).split('=');
    const key = parts[0];
    const value = parts.slice(1).join('=');
    params[key] = value;
  }
});

const templateName = params.template || 'nextjs-app';
const projectName = params.project || 'my-project';
const author = params.author || 'Your Name';

console.log('═════════════════════════════════════');
console.log(`🔧 Scaffolding Project: ${projectName}`);
console.log(`📦 Template: ${templateName}`);
console.log(`👤 Author: ${author}`);
console.log('═════════════════════════════════════\n');

// Load template configuration
const templateConfigPath = path.join(__dirname, '..', 'assets', 'template-config.json');

let templateConfig;
try {
  templateConfig = JSON.parse(fs.readFileSync(templateConfigPath, 'utf-8'));
} catch (error) {
  console.error(`❌ Error loading template config: ${error.message}`);
  process.exit(1);
}

const template = templateConfig.templates[templateName];

if (!template) {
  console.error(`❌ Template '${templateName}' not found`);
  console.error('\nAvailable templates:');
  Object.keys(templateConfig.templates).forEach(t => {
    console.error(`  - ${t}: ${templateConfig.templates[t].name}`);
  });
  process.exit(1);
}

console.log(`✅ Found template: ${template.name}\n`);
console.log(`📋 Description: ${template.description}\n`);

// Generate directory structure
const projectDir = path.join(process.cwd(), projectName);

if (fs.existsSync(projectDir)) {
  console.error(`❌ Directory '${projectName}' already exists`);
  process.exit(1);
}

console.log('📁 Creating directory structure...');

const structure = {
  'README.md': generateReadme(projectName, template),
  'src': {
    'components': {
      'index.tsx': '// Main component',
      'App.tsx': `// Root component\nexport default function App() {\n  return <div>Hello {projectName}</div>;\n}`
    },
    'lib': {
      'utils.ts': '// Utility functions'
    }
  },
  'tests': {
    'example.test.ts': '// Example test'
  },
  '.gitignore': generateGitignore(),
  '.env.example': 'DATABASE_URL=\nAPI_KEY='
};

function createDirectory(dir, content) {
  Object.entries(content).forEach(([name, item]) => {
    const fullPath = path.join(dir, name);

    if (typeof item === 'string') {
      fs.writeFileSync(fullPath, item, 'utf-8');
      console.log(`  ✅ Created: ${name}`);
    } else if (typeof item === 'object') {
      fs.mkdirSync(fullPath, { recursive: true });
      console.log(`  📁 Created directory: ${name}`);
      createDirectory(fullPath, item);
    }
  });
}

function generateReadme(name, template) {
  return `# ${name}

${template.description}

## Quick Start

\`\`\`\`bash
npm install
npm run dev
\`\`\`\`

## Project Structure

\`\`\`\`
src/
  components/    # React components
  lib/           # Utility functions
tests/          # Test files
\`\`\`\`

## Features

- Modern ${template.name}
- TypeScript for type safety
- Pre-configured tooling

## Next Steps

1. Update this README with project details
2. Configure environment variables in \`.env\`
3. Start building your features

---

Generated by project-template skill
`;
}

function generateGitignore() {
  return `# Dependencies
node_modules/

# Build output
dist/
build/
.next/

# Environment
.env
.env.local

# IDE
.vscode/
.idea/

# OS
.DS_Store
Thumbs.db

# Logs
*.log
`;
}

try {
  fs.mkdirSync(projectDir, { recursive: true });
  createDirectory(projectDir, structure);

  console.log('\n═════════════════════════════════════');
  console.log('✅ Project scaffolded successfully!');
  console.log('═════════════════════════════════════\n');
  console.log('🔗 Next steps:');
  console.log(`   cd ${projectName}`);
  console.log('   npm install');
  console.log('   npm run dev');
  console.log('\n📚 Happy coding!');

} catch (error) {
  console.error(`\n❌ Error scaffolding project: ${error.message}`);
  process.exit(1);
}

process.exit(0);
